# Environment: "development" or "production"
# In development, cron jobs run every 10 seconds for testing
NODE_ENV=development

# Enable or disable cron job execution
ENABLED=true

# Base URL for cron endpoints
# Use internal Docker network hostname (e.g., http://app:3000/api/cron)
# rather than localhost when running in Docker containers
URL="http://app:3000/api/cron"

# Authentication header name and value sent with each request
AUTH_HEADER="Authorization"
AUTH_HEADER_VALUE="your-secret-token"
